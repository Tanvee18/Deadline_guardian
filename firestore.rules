rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if request is from the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // User Preferences
    match /user_preferences/{prefId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid) && (request.resource == null || request.resource.data.user_id == request.auth.uid);
    }

    // Deadlines Collection
    match /deadlines/{deadlineId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid) && (request.resource == null || request.resource.data.user_id == request.auth.uid);
    }

    // Tasks Collection
    match /tasks/{taskId} {
      allow read, write: if isAuthenticated();
    }

    // Schedule Blocks
    match /schedule_blocks/{blockId} {
      allow read, write: if isAuthenticated();
    }

    // Drift Events
    match /drift_events/{eventId} {
      allow read, write: if isAuthenticated();
    }

    // Replan Logs
    match /replan_logs/{logId} {
      allow read, write: if isAuthenticated();
    }
  }
}
